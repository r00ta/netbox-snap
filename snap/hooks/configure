#!/bin/bash
# Configure hook for the NetBox snap.
#
# Responds to snap set / snap get for:
#   db.host, db.port, db.name, db.user, db.password
#   redis.host, redis.port, redis.password
#   http.port
#
# After changing any value, the hook regenerates configuration.py so the
# next service restart picks up the new settings.

set -eu

SNAP_DATA="${SNAP_DATA:-/var/snap/netbox/current}"
SNAP_COMMON="${SNAP_COMMON:-/var/snap/netbox/common}"
ENV_FILE="$SNAP_DATA/snap.env"
CONFIG_DIR="$SNAP_COMMON/config"
CONFIG_FILE="$CONFIG_DIR/configuration.py"

# --- read values (with defaults) ---

DB_HOST=$(snapctl get db.host)
DB_PORT=$(snapctl get db.port)
DB_NAME=$(snapctl get db.name)
DB_USER=$(snapctl get db.user)
DB_PASSWORD=$(snapctl get db.password)

REDIS_HOST=$(snapctl get redis.host)
REDIS_PORT=$(snapctl get redis.port)
REDIS_PASSWORD=$(snapctl get redis.password)

HTTP_PORT=$(snapctl get http.port)

# Apply defaults for anything unset
DB_HOST="${DB_HOST:-localhost}"
DB_PORT="${DB_PORT:-5432}"
DB_NAME="${DB_NAME:-netbox}"
DB_USER="${DB_USER:-netbox}"
DB_PASSWORD="${DB_PASSWORD:-}"

REDIS_HOST="${REDIS_HOST:-localhost}"
REDIS_PORT="${REDIS_PORT:-6379}"
REDIS_PASSWORD="${REDIS_PASSWORD:-}"

HTTP_PORT="${HTTP_PORT:-8080}"

# --- validate ports ---

validate_port() {
    local name="$1" value="$2"
    if ! echo "$value" | grep -qE '^[0-9]+$'; then
        echo "ERROR: ${name} must be a numeric port, got '${value}'" >&2
        return 1
    fi
    if [ "$value" -lt 1 ] || [ "$value" -gt 65535 ]; then
        echo "ERROR: ${name} must be 1-65535, got '${value}'" >&2
        return 1
    fi
}

validate_port "db.port" "$DB_PORT"
validate_port "redis.port" "$REDIS_PORT"
validate_port "http.port" "$HTTP_PORT"

# --- persist to environment file (sourced by common.sh) ---

cat > "$ENV_FILE" <<EOF
# Auto-generated by the netbox snap configure hook — do not edit.
NETBOX_DB_HOST=${DB_HOST}
NETBOX_DB_PORT=${DB_PORT}
NETBOX_DB_NAME=${DB_NAME}
NETBOX_DB_USER=${DB_USER}
NETBOX_DB_PASSWORD=${DB_PASSWORD}
NETBOX_REDIS_HOST=${REDIS_HOST}
NETBOX_REDIS_PORT=${REDIS_PORT}
NETBOX_REDIS_PASSWORD=${REDIS_PASSWORD}
NETBOX_HTTP_PORT=${HTTP_PORT}
EOF

# --- regenerate configuration.py ---

mkdir -p "$CONFIG_DIR"

# Preserve the SECRET_KEY and API_TOKEN_PEPPERS if the file already exists
SECRET_KEY=""
API_PEPPER=""
if [ -f "$CONFIG_FILE" ]; then
    SECRET_KEY=$(grep -oP "^SECRET_KEY = '\\K[^']+" "$CONFIG_FILE" 2>/dev/null || true)
    API_PEPPER=$(grep -oP "1: '\\K[^']+" "$CONFIG_FILE" 2>/dev/null || true)
fi

# Generate fresh secrets only when truly missing
if [ -z "$SECRET_KEY" ]; then
    SECRET_KEY=$(python3 -c "
import secrets, string
chars = string.ascii_letters + string.digits + '!@#%^&*(-_=+)'
print(''.join(secrets.choice(chars) for _ in range(50)))
" 2>/dev/null || head -c 50 /dev/urandom | base64 | head -c 50)
fi

if [ -z "$API_PEPPER" ]; then
    API_PEPPER=$(python3 -c "
import secrets, string
print(''.join(secrets.choice(string.ascii_letters + string.digits) for _ in range(60)))
" 2>/dev/null || head -c 60 /dev/urandom | base64 | head -c 60)
fi

cat > "$CONFIG_FILE" <<PYEOF
#
# NetBox snap auto-generated configuration
#
# This file is regenerated each time you run:
#   snap set netbox <key>=<value>
#
# To make changes that survive reconfiguration, edit the "User overrides"
# section at the bottom.  For the full list of settings see:
#   https://docs.netbox.dev/en/stable/configuration/
#

ALLOWED_HOSTS = ['*']

DATABASE = {
    'ENGINE': 'django.db.backends.postgresql',
    'NAME': '${DB_NAME}',
    'USER': '${DB_USER}',
    'PASSWORD': '${DB_PASSWORD}',
    'HOST': '${DB_HOST}',
    'PORT': ${DB_PORT},
    'CONN_MAX_AGE': 300,
}

REDIS = {
    'tasks': {
        'HOST': '${REDIS_HOST}',
        'PORT': ${REDIS_PORT},
        'USERNAME': '',
        'PASSWORD': '${REDIS_PASSWORD}',
        'DATABASE': 0,
        'SSL': False,
    },
    'caching': {
        'HOST': '${REDIS_HOST}',
        'PORT': ${REDIS_PORT},
        'USERNAME': '',
        'PASSWORD': '${REDIS_PASSWORD}',
        'DATABASE': 1,
        'SSL': False,
    },
}

SECRET_KEY = '${SECRET_KEY}'

API_TOKEN_PEPPERS = {
    1: '${API_PEPPER}',
}

MEDIA_ROOT = '${SNAP_COMMON}/media'
REPORTS_ROOT = '${SNAP_COMMON}/reports'
SCRIPTS_ROOT = '${SNAP_COMMON}/scripts'

DEBUG = False
LOGIN_REQUIRED = True

#
# ─── User overrides ──────────────────────────────────────────────────
# Add any custom settings below this line.  They will NOT be preserved
# if you run  snap set netbox ...  (the whole file is regenerated).
# For advanced customisation, disable the configure hook's regeneration
# by placing your own configuration.py and removing this comment block.
#
PYEOF

echo "Configuration updated.  Restart services to apply:"
echo "  sudo snap restart netbox"
